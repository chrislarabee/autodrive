[flake8]
# Recommend matching the black line length (default 88),
# rather than using the flake8 default of 79:
max-line-length = 88
extend-ignore =
    # See https://github.com/PyCQA/pycodestyle/issues/373
    E203,
    # black and flake8 disagree on spaces between variables and defaults 
    # (e.g. x = 123) in some contexts (particularly defaults for generic type
    # arguments), as usual we defer to black.
    E251,
exclude = 
    # black and flake8 disagree on how pyi files should be formatted, we defer
    # to black.
    *.pyi,